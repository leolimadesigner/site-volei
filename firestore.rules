rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isMaster() {
      return request.auth != null && request.auth.token.email == 'renato96.ram@gmail.com';
    }

    match /users/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
    }

    match /groups/{groupId} {
      // Leitura, criação e edição do grupo em si
      allow read: if isMaster() || (request.auth != null && request.auth.token.email in resource.data.memberEmails);
      allow create: if request.auth != null;
      allow update, delete: if isMaster() || (request.auth != null && (request.auth.uid in resource.data.adminUids || request.auth.token.email in resource.data.moderatorEmails));

      // ====================================================================
      // 1. SORTEIO E QUADRA (Livres para todos os membros)
      // Permite usar a aba Sorteio e jogar amistosos no Placar.
      // E exclui paymentSettings e charges da regra geral.
      // ====================================================================
      match /{collection}/{document=**} {
        allow read: if (collection != 'paymentSettings' && collection != 'charges') 
                    && (isMaster() || (request.auth != null && request.auth.token.email in get(/databases/$(database)/documents/groups/$(groupId)).data.memberEmails));
        
        // Se a coleção for 'teams' ou 'settings', qualquer membro pode interagir
        allow write: if (collection == 'teams' || collection == 'settings') 
                     && (isMaster() || (request.auth != null && request.auth.token.email in get(/databases/$(database)/documents/groups/$(groupId)).data.memberEmails));
      }

      // ====================================================================
      // 1.5 PAGAMENTOS (paymentSettings e charges)
      // ====================================================================
      match /paymentSettings/{document=**} {
        allow read: if isMaster() 
                    || (request.auth != null && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminUids || request.auth.token.email in get(/databases/$(database)/documents/groups/$(groupId)).data.moderatorEmails))
                    || (request.auth != null && request.auth.token.email in get(/databases/$(database)/documents/groups/$(groupId)).data.memberEmails);
        allow write: if isMaster() || (request.auth != null && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminUids || request.auth.token.email in get(/databases/$(database)/documents/groups/$(groupId)).data.moderatorEmails));
      }

      match /charges/{chargeId} {
        // Admin pode ler todas. Usuário só as suas.
        allow read: if isMaster() 
                    || (request.auth != null && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminUids || request.auth.token.email in get(/databases/$(database)/documents/groups/$(groupId)).data.moderatorEmails))
                    || (request.auth != null && resource.data.playerEmail == request.auth.token.email);
        
        // Apenas Admin pode criar/escrever cobranças pelo painel
        allow write: if isMaster() || (request.auth != null && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminUids || request.auth.token.email in get(/databases/$(database)/documents/groups/$(groupId)).data.moderatorEmails));
      }

      // ====================================================================
      // 2. DADOS CRÍTICOS: ELO E HISTÓRICO (Protegidos)
      // ====================================================================
      match /{collection}/{document=**} {
        allow write: if (collection == 'players' || collection == 'matchHistory') 
                     && (
                         isMaster() 
                         || (request.auth != null && (
                              request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminUids ||
                              request.auth.token.email in get(/databases/$(database)/documents/groups/$(groupId)).data.moderatorEmails
                            ))
                         || (
                              request.auth != null 
                              && request.auth.token.email in get(/databases/$(database)/documents/groups/$(groupId)).data.memberEmails 
                              && get(/databases/$(database)/documents/groups/$(groupId)/settings/global).data.eloEnabled == true
                            )
                     );
      }

      // ====================================================================
      // 3. AUTO-ATUALIZAÇÃO DE PERFIL (Membro atualiza seu próprio jogador)
      // Permite que o usuário atualize apenas seu próprio documento de player
      // ao salvar o perfil (nome e foto), sem precisar ser admin.
      // ====================================================================
      match /players/{playerId} {
        allow update: if request.auth != null
                      && request.auth.token.email in get(/databases/$(database)/documents/groups/$(groupId)).data.memberEmails
                      && resource.data.email == request.auth.token.email
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'photo', 'updatedAt']);
      }
    }
  }
}
